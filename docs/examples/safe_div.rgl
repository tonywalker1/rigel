; Demonstrates the fail algebraic effect for safe integer division.

(let safe-div (lambda (:args [a : int64] [b : int64]) (:returns int64) (:with (fail))
    (if (= b 0)
        (raise fail "division by zero")
        (/ a b))))

(handle
    (do
        (safe-div 10 0)
        (safe-div 10 2))
    (fail (msg) -1))
